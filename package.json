  "main": "index.js",
  "scripts": {
    "test": "rimraf allure-results && npx playwright test",
    "report:branding": "node -e \"const fs=require('fs');const src='allure-branding/styles.css';const dst='node_modules/allure-commandline/dist/plugins/custom-logo-plugin/static/styles.css';fs.copyFileSync(src,dst);const cfg='node_modules/allure-commandline/dist/config/allure.yml';const c=fs.readFileSync(cfg,'utf8');if(!c.includes('custom-logo-plugin'))fs.appendFileSync(cfg,'  - custom-logo-plugin\\n');\"",
    "report:generate": "npm run report:branding && npx allure generate allure-results -o allure-report --clean --name \"ICARE QUALITY\"",
    "report:open": "npx allure open allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
